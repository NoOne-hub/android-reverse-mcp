#!/usr/bin/env bash
set -euo pipefail

is_true() {
  case "${1:-}" in
    1|true|TRUE|yes|YES|on|ON) return 0 ;;
    *) return 1 ;;
  esac
}

wait_for_tcp() {
  local host="$1"
  local port="$2"
  local retries="${3:-120}"
  local i
  for ((i=0; i<retries; i++)); do
    if bash -c "exec 3<>/dev/tcp/${host}/${port}" >/dev/null 2>&1; then
      return 0
    fi
    sleep 1
  done
  return 1
}

if [ "$#" -gt 0 ] && [ "${1#-}" = "$1" ]; then
  exec "$@"
fi

HOST_VALUE="${HOST:-0.0.0.0}"
PORT_VALUE="${PORT:-8651}"
WORKSPACE_VALUE="${WORKSPACE_DIR:-${APK_MCP_WORKSPACE:-/workspace}}"
NATIVE_BACKEND_VALUE="${NATIVE_BACKEND:-}"
NATIVE_BACKEND_URL_VALUE="${NATIVE_BACKEND_URL:-}"

if [ -z "$NATIVE_BACKEND_VALUE" ] && [ -n "${GHIDRA_BACKEND:-}" ]; then
  NATIVE_BACKEND_VALUE="ghidra"
  NATIVE_BACKEND_URL_VALUE="${GHIDRA_BACKEND}"
fi

if [ -n "$NATIVE_BACKEND_VALUE" ] && [ -z "$NATIVE_BACKEND_URL_VALUE" ]; then
  case "$NATIVE_BACKEND_VALUE" in
    ghidra)
      NATIVE_BACKEND_URL_VALUE="tcp://ghidra-sidecar:${NATIVE_BACKEND_PORT:-8765}"
      ;;
    ida)
      NATIVE_BACKEND_URL_VALUE="http://ida-sidecar:${NATIVE_BACKEND_PORT:-8745}/mcp"
      ;;
    *)
      echo "[entrypoint] 不支持的 native backend: $NATIVE_BACKEND_VALUE" >&2
      exit 1
      ;;
  esac
fi

if [ -n "$NATIVE_BACKEND_URL_VALUE" ]; then
  case "$NATIVE_BACKEND_URL_VALUE" in
    http://*|https://*)
      BACKEND_ENDPOINT="${NATIVE_BACKEND_URL_VALUE#http://}"
      BACKEND_ENDPOINT="${BACKEND_ENDPOINT#https://}"
      BACKEND_ENDPOINT="${BACKEND_ENDPOINT%%/*}"
      BACKEND_HOST="${BACKEND_ENDPOINT%:*}"
      BACKEND_PORT="${BACKEND_ENDPOINT##*:}"
      ;;
    tcp://*)
      BACKEND_ENDPOINT="${NATIVE_BACKEND_URL_VALUE#tcp://}"
      BACKEND_HOST="${BACKEND_ENDPOINT%:*}"
      BACKEND_PORT="${BACKEND_ENDPOINT##*:}"
      ;;
    *)
      echo "[entrypoint] NATIVE_BACKEND_URL 仅支持 http(s)://host:port/path 或 tcp://host:port: $NATIVE_BACKEND_URL_VALUE" >&2
      exit 1
      ;;
  esac
  if ! wait_for_tcp "$BACKEND_HOST" "$BACKEND_PORT" 180; then
    echo "[entrypoint] native backend 未就绪: $NATIVE_BACKEND_URL_VALUE" >&2
    exit 1
  fi
fi

set -- android_reverse_mcp --http --host "$HOST_VALUE" --port "$PORT_VALUE" --workspace "$WORKSPACE_VALUE" "$@"

if [ -n "${APK:-}" ]; then
  set -- "$@" --apk "$APK"
fi

if [ -n "${THREADS:-}" ]; then
  set -- "$@" --threads "$THREADS"
fi

if [ -n "${BACKEND_URL:-}" ]; then
  set -- "$@" --backend-url "$BACKEND_URL"
fi

if [ -n "$NATIVE_BACKEND_VALUE" ]; then
  set -- "$@" --native-backend "$NATIVE_BACKEND_VALUE"
fi

if [ -n "$NATIVE_BACKEND_URL_VALUE" ]; then
  set -- "$@" --native-backend-url "$NATIVE_BACKEND_URL_VALUE"
fi

if [ -n "${BACKEND_JAR:-}" ]; then
  set -- "$@" --backend-jar "$BACKEND_JAR"
fi

if [ -n "${JADX_JAR:-}" ]; then
  set -- "$@" --jadx-jar "$JADX_JAR"
fi

DECODE_VALUE="${DECODE_ON_START:-}"
if [ -z "$DECODE_VALUE" ] && [ -n "${APK:-}" ]; then
  DECODE_VALUE=1
fi
if is_true "$DECODE_VALUE"; then
  set -- "$@" --decode-on-start
fi

exec "$@"
