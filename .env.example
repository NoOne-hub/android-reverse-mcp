# Main MCP service
APK_PATH=/absolute/path/to/target.apk
WORKSPACE_DIR=/absolute/path/to/android-reverse-workspace
PORT=8651
DECODE_ON_START=1

# Default full-stack mode: android-reverse-mcp + ghidra-sidecar
NATIVE_BACKEND=ghidra
NATIVE_BACKEND_PORT=8765
NATIVE_BACKEND_URL=
GHIDRA_PORT=8765
GHIDRA_HEADLESS_MCP_FAKE_BACKEND=0

# Switch to IDA by setting the following values instead:
# NATIVE_BACKEND=ida
# NATIVE_BACKEND_PORT=8745
# IDA_PORT=8745
# IDA_INPUT_PATH=/work/typed_fixture.elf
